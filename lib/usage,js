import { kvGet, kvIncr, kvExpire } from "./kv";

const FREE_DAILY_LIMIT = Number(process.env.FREE_DAILY_LIMIT || 5);

function todayKey() {
  return new Date().toISOString().slice(0, 10);
}

function usageKey(uid, dateKey = todayKey()) {
  return `uf:usage:${uid}:${dateKey}`;
}

export async function getUsageCount(uid) {
  if (!uid) return 0;

  const raw = await kvGet(usageKey(uid));
  return Number(raw || 0);
}

export async function incrementUsage(uid) {
  if (!uid) {
    throw new Error("Missing uid.");
  }

  const key = usageKey(uid);
  const value = await kvIncr(key);

  // expire after 3 days just to avoid stale keys building forever
  await kvExpire(key, 60 * 60 * 24 * 3);

  return Number(value || 0);
}

export async function canUseFreeTool(uid) {
  const used = await getUsageCount(uid);
  return used < FREE_DAILY_LIMIT;
}

export function getFreeDailyLimit() {
  return FREE_DAILY_LIMIT;
}
