import db from "./db.js";

export function getTodayString() {
  return new Date().toISOString().slice(0, 10);
}

export function getTodayUsageCount(userId, toolName = null) {
  const today = getTodayString();

  if (toolName) {
    const row = db.prepare(`
      SELECT COUNT(*) as count
      FROM usage_logs
      WHERE user_id = ? AND tool_name = ? AND used_on = ?
    `).get(userId, toolName, today);

    return row.count;
  }

  const row = db.prepare(`
    SELECT COUNT(*) as count
    FROM usage_logs
    WHERE user_id = ? AND used_on = ?
  `).get(userId, today);

  return row.count;
}

export function logUsage(userId, toolName) {
  db.prepare(`
    INSERT INTO usage_logs (user_id, tool_name, used_on)
    VALUES (?, ?, ?)
  `).run(userId, toolName, getTodayString());
}

export function enforcePlanLimit(user, toolName) {
  if (user.plan === "pro") {
    return { allowed: true };
  }

  const usedToday = getTodayUsageCount(user.id);
  const freeDailyLimit = 5;

  if (usedToday >= freeDailyLimit) {
    return {
      allowed: false,
      error: "Daily free limit reached. Upgrade to Pro for unlimited access."
    };
  }

  return { allowed: true };
}
