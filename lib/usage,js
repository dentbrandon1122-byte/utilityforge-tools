const usageStore = globalThis.__ufUsageStore || (globalThis.__ufUsageStore = {});

function getTodayKey() {
  return new Date().toISOString().slice(0, 10);
}

function ensureUsagePath(usageId, toolKey) {
  const today = getTodayKey();

  if (!usageStore[usageId]) usageStore[usageId] = {};
  if (!usageStore[usageId][today]) usageStore[usageId][today] = {};
  if (typeof usageStore[usageId][today][toolKey] !== "number") {
    usageStore[usageId][today][toolKey] = 0;
  }

  return {
    today,
    value: usageStore[usageId][today][toolKey]
  };
}

export function getUsageId(req, userId) {
  if (userId && typeof userId === "string" && userId.trim()) {
    return `user:${userId.trim()}`;
  }

  const forwarded = req?.headers?.["x-forwarded-for"];
  if (typeof forwarded === "string" && forwarded.length > 0) {
    return `ip:${forwarded.split(",")[0].trim()}`;
  }

  return `ip:${req?.socket?.remoteAddress || "unknown"}`;
}

export function getUsageCount(usageId, toolKey) {
  const { value } = ensureUsagePath(usageId, toolKey);
  return value;
}

export function incrementUsage(usageId, toolKey) {
  const today = getTodayKey();

  if (!usageStore[usageId]) usageStore[usageId] = {};
  if (!usageStore[usageId][today]) usageStore[usageId][today] = {};
  if (typeof usageStore[usageId][today][toolKey] !== "number") {
    usageStore[usageId][today][toolKey] = 0;
  }

  usageStore[usageId][today][toolKey] += 1;
  return usageStore[usageId][today][toolKey];
}
